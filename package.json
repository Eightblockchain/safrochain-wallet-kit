{
  "name": "@safrochain/wallet-kit",
  "version": "0.3.2",
  "description": "Plug-and-play wallet connection toolkit for Safrochain dApps",
  "keywords": [
    "safrochain",
    "cosmos",
    "wallet",
    "cosmos-kit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eightblockchain/safrochain-wallet-kit.git"
  },
  "homepage": "https://github.com/Eightblockchain/safrochain-wallet-kit#readme",
  "bugs": {
    "url": "https://github.com/Eightblockchain/safrochain-wallet-kit/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "CONTRIBUTING_WALLET.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@cosmos-kit/react": "^2",
    "@cosmos-kit/core": "^2",
    "@interchain-ui/react": "^1"
  },
  "peerDependenciesMeta": {
    "@interchain-ui/react": {
      "optional": true
    }
  },
  "dependencies": {
    "axios": "^1.0.0",
    "@cosmos-kit/keplr": "^2.17.0",
    "@cosmos-kit/leap": "^2.17.0",
    "@cosmos-kit/cosmostation": "^2.17.0"
  },
  "devDependencies": {
    "@cosmos-kit/core": "^2.18.0",
    "@cosmos-kit/react": "^2.24.0",
    "@cosmjs/amino": "^0.32.0",
    "@cosmjs/proto-signing": "^0.32.0",
    "@interchain-ui/react": "^1.26.3",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
